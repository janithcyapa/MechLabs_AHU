{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ESP-IDF Build",
      "type": "shell",
      "command": "idf.py",
      "args": [
        "-C",
        "${workspaceFolder}/Firmware",
        "-B",
        "${workspaceFolder}/Firmware/build",
        "build"
      ],
      "options": {
        "env": {
          "IDF_PATH": "/home/jazz/.espressif/v6.0/esp-idf"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
